# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
#
# Generate a deploy key first:
#   ssh-keygen -t ed25519 -f ~/.ssh/pso-server-deploy -C 'pso-server deploy' -N ''
# Then paste the contents of ~/.ssh/pso-server-deploy.pub below.

ssh_public_key = "ssh-ed25519 AAAA... pso-server deploy"

# DNS server (UDP 53) allowlist. newserv's built-in DNS resolves any name to the
# server's IP, so an open resolver is a mild DNS-reflection risk. But Blue Burst
# clients resolve pso.joshkautz.com via public DNS (not this one) and the game
# ports are open to all, so this allowlist only ever gated console clients. The
# real access control is the account gate (AllowUnregisteredUsers=false in
# server/config.json): only pre-created accounts can log in. Default is open; to
# lock DNS down instead, list each player's home public IP as a /32:
#   allowed_dns_cidrs = ["73.242.54.43/32", "1.2.3.4/32"]
allowed_dns_cidrs = ["0.0.0.0/0"]

# Optional overrides:
# aws_region         = "us-east-1"
# availability_zone  = "us-east-1a"
# instance_bundle_id = "small_3_0"
# allowed_admin_cidr = "203.0.113.42/32"   # your home IP, for SSH lockdown
# allowed_game_cidr  = "0.0.0.0/0"         # PSO game ports — open by default
