@@ -13,6 +13,26 @@ static const D3DFORMAT AdapterFormats[] = {
 	D3DFMT_A1R5G5B5
 };
 
+// d3d8to9-windowed: give the game window real title-bar buttons (close / minimize)
+// and make the red close button quit the process cleanly, so closing the macOS
+// window tears the whole app down (game + Wine) at once.
+static WNDPROC g_origWndProc = nullptr;
+static LRESULT CALLBACK WindowedWndProc(HWND hwnd, UINT msg, WPARAM wParam, LPARAM lParam)
+{
+	if (msg == WM_CLOSE)
+		ExitProcess(0);
+	return CallWindowProc(g_origWndProc, hwnd, msg, wParam, lParam);
+}
+static void MakeWindowDecorated(HWND hwnd)
+{
+	if (hwnd == nullptr)
+		return;
+	SetWindowLongPtr(hwnd, GWL_STYLE, GetWindowLongPtr(hwnd, GWL_STYLE) | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX | WS_MAXIMIZEBOX);
+	SetWindowPos(hwnd, nullptr, 0, 0, 0, 0, SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_FRAMECHANGED);
+	if (g_origWndProc == nullptr)
+		g_origWndProc = reinterpret_cast<WNDPROC>(SetWindowLongPtr(hwnd, GWLP_WNDPROC, reinterpret_cast<LONG_PTR>(WindowedWndProc)));
+}
